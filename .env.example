# Database Configuration
# Using CARDS_DATABASE_URL instead of DATABASE_URL to avoid conflict with Chainlit's data layer
CARDS_DATABASE_URL=sqlite+aiosqlite:///./data/cards.db

# Scryfall bulk data type (configured via import script --type flag, not environment variable)
# Default: default_cards (~60k cards, 200MB, 6-9 min import)
#   - Includes all printings (multiple versions of same card from different sets)
#   - Required for Universes Within cards (OM1 "Through the Omenpaths", etc.)
#   - Accurate Arena/MTGO platform filtering via games field
#   - May show duplicate card names in search results (different sets)
# Alternative: oracle_cards (~30k cards, 79MB, 2-3 min import)
#   - One canonical card per Oracle ID (smaller database, faster import)
#   - May miss alternate-name printings (OM1 cards have different names than paper versions)
#   - Better for disk-constrained environments
# Usage: uv run python scripts/import_scryfall_data.py --type default_cards

# API Configuration
# At least one API key is required (ANTHROPIC_API_KEY or OPENROUTER_API_KEY)
#
# Option 1: Anthropic API (Recommended for Claude models)
# - Direct API access to Claude models (claude-sonnet-4.5, claude-opus-4, etc.)
# - More reliable tool calling (no translation layer)
# - Access to Anthropic-specific features (prompt caching)
# - Sign up at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here
#
# Option 2: OpenRouter API (For non-Claude models or multi-model access)
# - Access to multiple model providers through one API
# - Useful for GPT, Gemini, Llama, and other non-Claude models
# - Sign up at: https://openrouter.ai/
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Agent Configuration
# Model name depends on which API key you're using:
# - With ANTHROPIC_API_KEY: Use "claude-haiku-4-5", "claude-sonnet-4-5", "claude-opus-4" (no "anthropic/" prefix)
# - With OPENROUTER_API_KEY: Use "anthropic/claude-sonnet-4.5", "openai/gpt-4", etc. (with provider prefix)
# The agent automatically selects the correct provider based on:
#   1. For Claude models: Prefers Anthropic API if ANTHROPIC_API_KEY is set
#   2. For non-Claude models: Uses OpenRouter API if OPENROUTER_API_KEY is set
AGENT_MODEL=claude-haiku-4-5
AGENT_TEMPERATURE=0.7
AGENT_MAX_TOKENS=4096

# Application Configuration
# Visual Mana Symbols - Render mana costs as SVG images from Scryfall CDN (default: true)
# Set to false to use text notation instead (e.g., for accessibility or debugging)
VISUAL_MANA_SYMBOLS=true

# Card Image Hover Preview - Display card images on hover over card names (default: true)
# Wraps card names with HTML hover functionality to show Scryfall card images
# Set to false to display plain text card names without hover preview
CARD_IMAGE_HOVER_ENABLED=true

# Card Hover Direction - Control which side card image previews appear on (default: right)
# Options: "right" (card appears right of name), "left" (card appears left of name)
# Useful when sidebar is on right side - set to "left" to prevent overlap
# Note: Sidebar deck panel always uses left hover regardless of this setting
CARD_HOVER_DIRECTION=right

# Pydantic Logfire Observability (Optional)
# Enable distributed tracing and observability for agent, database, and HTTP requests
# To use Logfire:
#   1. Sign up for free account at https://logfire.pydantic.dev/
#   2. Create a project or use the default project
#   3. Get your API token from the Logfire dashboard (Settings > API Tokens)
#   4. Set LOGFIRE_ENABLED=true and provide your token below
# When disabled (default), zero overhead - no instrumentation loaded
LOGFIRE_ENABLED=false
LOGFIRE_TOKEN=
LOGFIRE_PROJECT=artificial-planeswalker
