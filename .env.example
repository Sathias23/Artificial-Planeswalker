# Artificial-Planeswalker environment template.
#
# The current app is a stateless MCP server (src/mcp_server), consumed by an MCP
# client such as Claude Code. The client is the LLM — the server makes NO LLM calls,
# so NO API key is required. Both settings below have sensible defaults; copying this
# file to .env is optional.

# Database Configuration
# Using CARDS_DATABASE_URL instead of DATABASE_URL to avoid conflict with Chainlit's data layer
CARDS_DATABASE_URL=sqlite+aiosqlite:///./data/cards.db

# MCP transport (read by src/mcp_server). Default: stdio (how MCP clients launch it).
# Override to "sse" or "streamable-http" to serve over HTTP instead.
MCP_TRANSPORT=stdio

# fastembed model cache (read by src/search). Default: ./data/fastembed_cache — a persistent
# path beside cards.db so the ~80MB bge-small-en-v1.5 model survives reboots/Temp cleanup and
# loads offline after the first download. Override only to relocate the cache; pin it to a
# PERSISTENT path — never fastembed's volatile %TEMP%\fastembed_cache default.
# FASTEMBED_CACHE_DIR=./data/fastembed_cache

# Scryfall bulk data type (configured via import script --type flag, not environment variable)
# Default: default_cards (~60k cards, 200MB, 6-9 min import)
#   - Includes all printings (multiple versions of same card from different sets)
#   - Required for Universes Within cards (OM1 "Through the Omenpaths", etc.)
#   - Accurate Arena/MTGO platform filtering via games field
#   - May show duplicate card names in search results (different sets)
# Alternative: oracle_cards (~30k cards, 79MB, 2-3 min import)
#   - One canonical card per Oracle ID (smaller database, faster import)
#   - May miss alternate-name printings (OM1 cards have different names than paper versions)
#   - Better for disk-constrained environments
# Usage: uv run python scripts/import_scryfall_data.py --type default_cards

# ============================================================================
# LEGACY ONLY — the settings below are used by the archived PydanticAI + Chainlit
# stack under legacy/ (install with `uv sync --group legacy`). The MCP server does
# NOT read any of them. Leave them unset unless you are running the legacy app.
# ============================================================================

# LLM provider keys (legacy agent only) — set at least one to run legacy/.
# Anthropic: https://console.anthropic.com/  ·  OpenRouter: https://openrouter.ai/
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
# OPENROUTER_API_KEY=your_openrouter_api_key_here

# Legacy agent model/sampling config.
# AGENT_MODEL=claude-haiku-4-5
# AGENT_TEMPERATURE=0.7
# AGENT_MAX_TOKENS=4096

# Legacy Chainlit UI rendering toggles.
# VISUAL_MANA_SYMBOLS=true
# CARD_IMAGE_HOVER_ENABLED=true
# CARD_HOVER_DIRECTION=right

# Legacy Pydantic Logfire observability (sign up at https://logfire.pydantic.dev/).
# LOGFIRE_ENABLED=false
# LOGFIRE_TOKEN=
# LOGFIRE_PROJECT=artificial-planeswalker
