# Claude Code — track shared skills/config, keep machine-local settings out
.claude/settings.local.json

# Codex — repo-scoped personal config (the .codex analog of settings.local.json)
/.codex/

# Dev process tooling — untracked via `git rm --cached` but kept ON DISK locally so the bmad
# workflow still runs. NOTE: _bmad-output/ is intentionally NOT ignored — its planning +
# implementation artifacts are the public design record.
/_bmad/
.claude/skills/bmad-*/
# BMAD installer dump for Codex-style agents — dev tooling, not shipped. Scoped to skills/ only:
# .agents/plugins/ (the Codex marketplace file) IS committed, so never blanket-ignore .agents/.
.agents/skills/

